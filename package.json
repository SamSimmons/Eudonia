{
  "name": "eudonia-workspace",
  "private": true,
  "type": "module",
  "packageManager": "bun@1.3.1",
  "workspaces": [
    "packages/*",
    "examples/react/*",
    "tests/browser"
  ],
  "scripts": {
    "test": "bun run test:unit && bun run test:layout",
    "test:unit": "bun test --cwd packages/eudonia",
    "test:layout": "bunx playwright test --config=tests/browser/playwright.config.ts --project=layout",
    "test:perf": "bunx playwright test --config=tests/browser/playwright.config.ts --project=perf",
    "test:all": "bun run test:unit && bunx playwright test --config=tests/browser/playwright.config.ts",
    "check:bundle-size": "bun run scripts/check-bundle-size.ts",
    "typecheck": "tsc --build"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@types/bun": "^1.3.12",
    "playwright": "^1.59.1",
    "typescript": "^6.0.2"
  }
}
