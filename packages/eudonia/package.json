{
  "name": "eudonia",
  "version": "0.1.0",
  "type": "module",
  "exports": {
    "./layout": {
      "types": "./dist/layout.d.ts",
      "import": "./dist/layout.js",
      "default": "./dist/layout.js"
    },
    "./components": {
      "types": "./dist/components.d.ts",
      "import": "./dist/components.js",
      "default": "./dist/components.js"
    },
    "./components.css": "./dist/components.css",
    "./theme.css": "./dist/theme.css"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "rm -rf dist tsconfig.build.tsbuildinfo && rollup -c && tsc -p ./tsconfig.build.json && cp src/theme.css dist/theme.css",
    "dev": "rollup -c -w & tsc -p ./tsconfig.build.json --watch --preserveWatchOutput",
    "prepack": "bun run build",
    "test": "bun test",
    "typecheck": "tsc -p ./tsconfig.json --noEmit",
    "lint": "eslint src"
  },
  "peerDependencies": {
    "react": "^19.2.0",
    "react-dom": "^19.2.0"
  },
  "devDependencies": {
    "@eslint-react/eslint-plugin": "^4.2.3",
    "@eslint/js": "^10.0.1",
    "@happy-dom/global-registrator": "^20.8.9",
    "@rollup/plugin-node-resolve": "^16.0.3",
    "@testing-library/react": "^16.3.2",
    "@types/bun": "^1.3.12",
    "@types/d3-array": "^3.2.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "eslint": "^10.2.1",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-you-might-not-need-an-effect": "^0.9.3",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "rollup": "^4.60.1",
    "rollup-plugin-esbuild": "^6.2.1",
    "rollup-plugin-postcss": "^4.0.2",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.58.2"
  },
  "dependencies": {
    "@visx/axis": "^3.12.0",
    "@visx/grid": "^3.12.0",
    "@visx/responsive": "^3.12.0",
    "@visx/scale": "^3.12.0",
    "@visx/shape": "^3.12.0",
    "d3-array": "^3.2.4"
  }
}
