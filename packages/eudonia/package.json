{
  "name": "eudonia",
  "version": "0.1.0",
  "type": "module",
  "exports": {
    "./layout": {
      "types": "./dist/layout.d.ts",
      "import": "./dist/layout.js",
      "default": "./dist/layout.js"
    },
    "./components": {
      "types": "./dist/components.d.ts",
      "import": "./dist/components.js",
      "default": "./dist/components.js"
    },
    "./components.css": "./dist/components.css"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "bun build ./src/layout.ts ./src/components.ts --outdir ./dist --format esm --target browser --external react --external react-dom && tsc -p ./tsconfig.build.json",
    "dev": "bun build ./src/layout.ts ./src/components.ts --outdir ./dist --format esm --target browser --external react --external react-dom --watch & tsc -p ./tsconfig.build.json --watch --preserveWatchOutput",
    "prepack": "bun run build",
    "test": "bun test",
    "typecheck": "tsc -p ./tsconfig.json --noEmit"
  },
  "peerDependencies": {
    "react": "^19.2.0",
    "react-dom": "^19.2.0"
  },
  "devDependencies": {
    "@happy-dom/global-registrator": "^20.8.9",
    "@testing-library/react": "^16.3.2",
    "@types/bun": "^1.3.12",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "typescript": "^6.0.2"
  }
}
