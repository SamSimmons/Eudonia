{
  "name": "eudonia",
  "version": "0.1.0",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "bun build ./src/index.ts --outdir ./dist --format esm --target browser --external react --external react-dom && tsc -p ./tsconfig.build.json",
    "dev": "bun build ./src/index.ts --outdir ./dist --format esm --target browser --external react --external react-dom --watch & tsc -p ./tsconfig.build.json --watch --preserveWatchOutput",
    "prepack": "bun run build",
    "test": "bun test",
    "typecheck": "tsc -p ./tsconfig.json --noEmit"
  },
  "peerDependencies": {
    "react": "^19.2.0",
    "react-dom": "^19.2.0"
  },
  "devDependencies": {
    "@happy-dom/global-registrator": "^20.8.9",
    "@testing-library/react": "^16.3.2",
    "@types/bun": "^1.3.12",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "typescript": "^6.0.2"
  }
}
